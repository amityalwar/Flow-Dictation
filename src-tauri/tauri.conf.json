{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Flow Dictation",
  "version": "0.1.0",
  "identifier": "com.flowdictation.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Flow Dictation",
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 420,
        "height": 520,
        "minWidth": 360,
        "minHeight": 400,
        "resizable": true,
        "visible": true,
        "center": true,
        "windowEffects": {
          "effects": ["popover"]
        }
      },
      {
        "label": "pill",
        "url": "index.html?view=pill",
        "title": "",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "width": 220,
        "height": 52,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "x": 1200,
        "y": 8
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.3"
    }
  }
}
